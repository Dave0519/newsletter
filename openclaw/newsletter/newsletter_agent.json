{
  "agentName": "뉴스레터",
  "timezone": "Asia/Seoul",
  "defaultChannel": "email",
  "defaultSendTime": "06:00",
  "workflow": [
    "ask_user_name",
    "ask_user_needs_freeform",
    "normalize_needs_to_schema",
    "assign_serial_number",
    "confirm_schedule_and_start"
  ],
  "customerStore": {
    "path": "newsletter_customers.json",
    "sourceOfTruth": true
  },
  "stateStore": {
    "latest": "newsletter_agent_state.json",
    "runs": "newsletter_runs.jsonl",
    "audit": "newsletter_audit.jsonl"
  },
  "collection": {
    "mode": "per_recipient_isolated_first",
    "sharedPoolReuseMaxRatio": 0.4,
    "lookbackHours": 48,
    "priorityCategories": [
      "AI_TECH",
      "INDUSTRY",
      "SEMICONDUCTOR"
    ],
    "needsGrouping": {
      "enabled": true,
      "searchPerGroup": true,
      "minGroupsInFinal": 2,
      "maxSingleGroupShare": 0.5,
      "targetMix": {
        "primary": "0.40-0.50",
        "secondary": "0.20-0.35",
        "tertiary": "0.15-0.25"
      },
      "rebalanceBeforeSend": true
    },
    "minArticlesPerNewsletter": 6,
    "softMinArticlesPerNewsletter": 8,
    "targetArticlesPerNewsletter": 10,
    "countryMixGuideline": {
      "US": "40-50%",
      "KR": "20-30%",
      "CN": "10-20%",
      "TW": "10-15%",
      "GLOBAL": "10-20%"
    },
    "dynamicCountrySections": true,
    "hideEmptyCountrySections": true,
    "hashtags": {
      "enabled": true,
      "count": "3-5",
      "source": "customer_needs_top_keywords",
      "placement": "below_global_scan_intro",
      "style": "small_gray_inline"
    }
  },
  "schedule": {
    "kind": "daily",
    "time": "06:00",
    "enabled": true,
    "retry": {
      "enabled": true,
      "time": "06:10",
      "maxRetry": 1
    }
  },
  "publishSwitch": {
    "enabled": true,
    "description": "06:00 실행 시 이 값이 false면 발행하지 않음"
  },
  "deliveryPipeline": {
    "stages": [
      "collect_per_recipient_isolated",
      "resolve_original_links",
      "extract_article_body",
      "ai_generate_korean_title_summary",
      "ai_generate_practical_implication",
      "build_summary_from_global_scan",
      "render_template_strict",
      "validate_quality_gates_tiered",
      "final_relevance_review_and_refine",
      "send"
    ],
    "articleCountShortageCauses": [
      "link_validation_drop",
      "body_extraction_failure",
      "source_pool_too_narrow"
    ],
    "shortageMitigation": [
      "expand_source_pool",
      "retry_link_resolution",
      "retry_body_extraction",
      "needs-adjacent_refetch"
    ],
    "failFast": true,
    "onValidationFail": "stop_and_regenerate"
  },
  "runtimePolicy": {
    "pythonExecution": "forbidden",
    "exceptions": false,
    "allowedExecution": [
      "agent_only"
    ],
    "writingEngine": "ai_only",
    "forbidProgrammaticWriting": true,
    "description": "파이썬 임시 스크립트/로컬 로직 실행 금지. 작성(제목/요약/실무시사점)은 AI만 수행하며, 코드는 수집/검증/렌더/발송 오케스트레이션에만 사용"
  },
  "renderPolicy": {
    "template": "CLUE_TEMPLATE_OFFICIAL",
    "preserveOriginalArticleBlock": true,
    "allowCustomCardLayout": false,
    "summaryMode": "top5_bullets",
    "summaryItemMaxSentences": 2,
    "summaryNameMention": false,
    "summaryAlignment": "justify",
    "summaryParagraphMode": "single_paragraph_no_linebreak",
    "articleSummaryLines": "4-5",
    "practicalImplication": {
      "enabled": true,
      "label": "실무 시사점",
      "lines": "3-4",
      "tone": "practical_balanced_non_assertive",
      "audienceFocus": [
        "customer_work",
        "SK_hynix"
      ],
      "forbiddenLeadPhrases": [
        "실무에서는",
        "SK hynix에서는",
        "업무 관점에서는",
        "업무 관점에서",
        "메모리 산업 관점에서도",
        "메모리 산업 관점에서"
      ]
    },
    "sourceValidation": {
      "requireExtractedBody": true,
      "summaryEvidenceCheck": true,
      "noOverInterpretation": true,
      "neutralToneOnly": true,
      "forbidThirdPersonCommentary": true,
      "forbiddenPhrases": [
        "기사에는",
        "기사 본문에서는",
        "기사에서는",
        "제시합니다",
        "평가합니다",
        "로 볼 수 있습니다"
      ]
    }
  },
  "mailSubjectPolicy": {
    "fixedPrefix": "[CLUE]",
    "fixedTitle": "AI BRIEFING | 오늘의 글로벌 핵심 동향"
  },
  "consistencyValidation": {
    "summaryMustBeDerivedFromGlobalScan": true,
    "perRecipientCollectionIsolation": true,
    "blockSendOnMismatch": true,
    "templateStrictMode": true,
    "blockManualHtmlSend": true,
    "requiredTemplateChecks": [
      "xhtml_doctype",
      "preheader",
      "header_date_no_block",
      "global_scan_block",
      "footer_block",
      "bottom_orange_line"
    ],
    "mustHideGlobalResearchInsight": true,
    "requirePracticalImplicationBlock": true,
    "requireKoreanTitle": true,
    "requireKoreanSummary": true,
    "articleSummarySentenceRange": [
      4,
      5
    ],
    "summarySentenceMaxPerItem": 2,
    "summaryItems": 5,
    "summaryFallbackAllowed": false,
    "enforceSingleArticleGrounding": true,
    "enforceCountrySectionRendering": true,
    "minCountrySections": 3,
    "softMinCountrySections": 2,
    "titleCompression": "minimal",
    "minimumTitleInfoUnits": 3,
    "forbidOverCompressedTitle": true,
    "independentCollectionProof": {
      "required": true,
      "maxUrlOverlapRatio": 0.7,
      "softMaxUrlOverlapRatio": 0.8
    },
    "linkValidation": {
      "required": true,
      "minPassRate": 0.8,
      "softMinPassRate": 0.7,
      "forbidDomains": [
        "news.google.com"
      ],
      "requireDistinctPerArticle": true,
      "allowRetryResolution": true,
      "maxResolutionAttempts": 3,
      "onFail": "drop_article_or_refetch"
    },
    "finalRelevanceReview": {
      "enabled": true,
      "runAt": "pre_send_last_step",
      "keepExistingFlow": true,
      "requireDirectNeedMatch": true,
      "dropIfLowRelevance": true,
      "dropExamples": [
        "generic_real_estate",
        "general_lifestyle"
      ],
      "regenerateIfBelowHardMin": true,
      "hardMinArticles": 6,
      "publishOnlyReviewedMatches": true
    }
  },
  "issueNumber": {
    "next": 1,
    "format": "3-digit"
  },
  "notes": "customers.json 이중관리 금지. newsletter_customers.json 단일 원천 사용",
  "gitOpsPolicy": {
    "autoCommitOnOperationalChange": true,
    "autoPushOnCommit": true,
    "repo": "https://github.com/Dave0519/newsletter.git",
    "requiredSnapshotFiles": [
      "openclaw/newsletter/newsletter_agent_prompt.md",
      "openclaw/newsletter/newsletter_agent.json",
      "openclaw/newsletter/newsletter_customers.json",
      "openclaw/newsletter/newsletter_runs.jsonl",
      "openclaw/cron/jobs.json"
    ],
    "requireCustomerInfoInCommitMessageOnAdd": true,
    "requirePostPushVerification": true
  },
  "model": {
    "provider": "openai",
    "name": "gpt-4o",
    "temperature": 0.3,
    "max_tokens": 4096,
    "tools": []
  },
  "executionMode": {
    "perCustomerIsolation": true,
    "sessionReset": "per_customer"
  },
  "concurrency": {
    "perCustomerParallel": true,
    "maxParallelCustomers": "enabled_count",
    "notes": "enabled=true 고객을 병렬 처리하되, 고객별 수집/요약/검증 컨텍스트는 완전 분리"
  },
  "templateSha256": "6ad67d7e06f91cddfe1610908758f231899a4e192ee53bd3907d02a867e5f132"
}
